@page "/"
@inject HttpClient Http
@inject NavigationManager Navigation

<h3>Employee List</h3>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<button class="btn btn-primary mb-3" @onclick="AddEmployee">Add New Employee</button>

@if (employees == null)
{
    <p><em>Loading...</em></p>
}
else if (!employees.Any())
{
    <p>No employees found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Position</th>
                <th>Department</th>
                <th>Salary</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in employees)
            {
                <tr>
                    <td>@emp.Id</td>
                    <td>@emp.Name</td>
                    <td>@emp.Position</td>
                    <td>@emp.Department</td>
                    <td>@emp.Salary.ToString("C")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary me-2" @onclick="() => EditEmployee(emp.Id)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteEmployee(emp.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private CancellationTokenSource? messageCts;
    private string? successMessage;
    private string? errorMessage;

    private List<Employee>? employees;

    private async Task ShowSuccessMessage(string message)
    {
        messageCts?.Cancel();
        messageCts = new CancellationTokenSource();
        successMessage = message;
        errorMessage = null;
        StateHasChanged();

        try
        {
            await Task.Delay(5000, messageCts.Token);
            successMessage = null;
            StateHasChanged();
        }
        catch (TaskCanceledException)
        {
            // TODO
        }
    }

    private async Task ShowErrorMessage(string message)
    {
        messageCts?.Cancel();
        messageCts = new CancellationTokenSource();
        errorMessage = message;
        successMessage = null;
        StateHasChanged();

        try
        {
            await Task.Delay(5000, messageCts.Token);
            errorMessage = null;
            StateHasChanged();
        }
        catch (TaskCanceledException)
        {
            // TODO
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("success", out var message))
            successMessage = message;

        try
        {
            employees = await Http.GetFromJsonAsync<List<Employee>>("employees");
        }
        catch (HttpRequestException ex) when (ex.Message.Contains("CORS", StringComparison.OrdinalIgnoreCase))
        {
            // CORS error handler
            employees = new List<Employee>();
            Console.Error.WriteLine("CORS error: " + ex.Message);
        }
        catch (Exception ex)
        {
            // Other generic errors
            employees = new List<Employee>();
            Console.Error.WriteLine("General error: " + ex.Message);
        }
    }

    void AddEmployee()
    {
        Navigation.NavigateTo("/add");
    }

    void EditEmployee(int id)
    {
        Navigation.NavigateTo($"/edit/{id}");
    }

    async Task DeleteEmployee(int id)
    {
        successMessage = errorMessage = null; // Clear previous error

        var employee = employees?.FirstOrDefault(employee => employee.Id == id);
        string employeeName = employee?.Name ?? $"ID {id}";

        // Show confirmation dialog
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete employee '{employeeName}' with id {id}?");

        if (!confirmed)
            return;

        try
        {
            var response = await Http.DeleteAsync($"employees/{id}");

            if (response.IsSuccessStatusCode)
            {
                // Re-fetching the list from the backend
                employees = await Http.GetFromJsonAsync<List<Employee>>("employees");
                await ShowSuccessMessage($"Employee '{employeeName}' with id {id} was deleted successfully.");
            }
            else
            {
                await ShowErrorMessage($"Failed to delete employee '{employeeName}' with id {id}. Maybe it was already deleted.");
            }
        }
        catch (Exception ex)
        {
            await ShowErrorMessage($"Error deleting '{employeeName}' with id {id}: {ex.Message}");
        }
    }

    public class Employee
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Position { get; set; } = string.Empty;
        public string Department { get; set; } = string.Empty;
        public decimal Salary { get; set; }
    }
}
