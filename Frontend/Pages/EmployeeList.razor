@page "/"
@inject Microsoft.Extensions.Logging.ILogger<EmployeeListViewModel> employeeListLogger
@inject IToastNotificationService ToastService
@inject IDialogService DialogService

@if (_viewModel != null && _viewModel.Initialized)
{
    <PageTitle>@_viewModel.PageTitle</PageTitle>
    <h3>Employee List</h3>

    <div class="mb-3">
        <DxTextBox CssClass="w-100"
                   NullText="Search by Name, Position or Department"
                   Text="@_viewModel.SearchTerm"
                   TextChanged="OnSearchTextChanged" />
    </div>

    <div class="mb-3 d-flex align-items-end gap-3 flex-wrap">
        <div>
            <label class="form-label">Page Size</label>
            <DxComboBox Data="@PageSizes"
                        TData="int"
                        TValue="int"
                        @bind-Value="SelectedPageSize"
                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never"
                        CssClass="page-size-combo" />
        </div>

        <DxButton Text="Add New Employee"
                  RenderStyle="ButtonRenderStyle.Primary"
                  Click="@_viewModel.AddEmployee" />
    </div>

    @if (!string.IsNullOrWhiteSpace(_viewModel.ErrorMessage) && (_viewModel.Employees?.Any() ?? false))
    {
        <div class="alert alert-danger" role="alert">
            @_viewModel.ErrorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_viewModel.ErrorMessage) && !(_viewModel.Employees?.Any() ?? false))
    {
        <p>Employee data is temporarily unavailable.</p>
    }
    else if (!(_viewModel.Employees?.Any() ?? false))
    {
        <p>No employees found.</p>
    }
    else
    {
        <DxGrid Data="@_viewModel.Employees"
                CssClass="mb-3">
            <Columns>
                <DxGridDataColumn FieldName="@nameof(EmployeeViewModel.Id)" Caption="Id" />
                <DxGridDataColumn FieldName="@nameof(EmployeeViewModel.Name)" Caption="Name" />
                <DxGridDataColumn FieldName="@nameof(EmployeeViewModel.Position)" Caption="Position" />
                <DxGridDataColumn FieldName="@nameof(EmployeeViewModel.Department)" Caption="Department" />
                <DxGridDataColumn FieldName="@nameof(EmployeeViewModel.Salary)" Caption="Salary">
                    <CellDisplayTemplate Context="cellContext">
                        @{
                            var employee = (EmployeeViewModel)cellContext.DataItem;
                        }
                        @(employee.Salary.HasValue ? employee.Salary.Value.ToString("C") : "N/A")
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn Caption="Actions">
                    <CellDisplayTemplate Context="cellContext">
                        @{
                            var employee = (EmployeeViewModel)cellContext.DataItem;
                        }
                        <div class="d-flex gap-2">
                            <DxButton Text="Edit"
                                      RenderStyle="ButtonRenderStyle.Secondary"
                                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                                      Click="@(() => _viewModel.EditEmployee(employee.Id))" />
                            <DxButton Text="Delete"
                                      RenderStyle="ButtonRenderStyle.Danger"
                                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                                      Click="@(() => ConfirmDeleteAsync(employee))" />
                        </div>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
        </DxGrid>

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>
                Showing @_viewModel.FirstItemNumber-@_viewModel.LastItemNumber of @_viewModel.TotalCount employees
                (page @_viewModel.CurrentPage of @_viewModel.TotalPages)
            </span>

            <DxPager PageCount="@_viewModel.TotalPages"
                     @bind-ActivePageIndex="PagerActivePageIndex"
                     NavigationMode="PagerNavigationMode.NumericButtons"
                     VisibleNumericButtonCount="5" />
        </div>
    }
}
else
{
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
}

@code {
    private EmployeeListViewModel? _viewModel;
    private static readonly IReadOnlyList<int> PageSizes = [5, 10, 20, 50];
    private int _selectedPageSize = 10;
    private int _pagerActivePageIndex;

    protected override async Task OnInitializedAsync()
    {
        _viewModel = new EmployeeListViewModel(this, client, navigationManager, JSRuntime, employeeListLogger);
        await _viewModel.InitializeAsync(navigationManager.Uri);
        SyncPagerState();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_viewModel is null)
            return;

        if (!string.IsNullOrWhiteSpace(_viewModel.SuccessMessage))
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Success",
                Text = _viewModel.SuccessMessage,
                RenderStyle = ToastRenderStyle.Success,
                ThemeMode = ToastThemeMode.Pastel
            });

            _viewModel.SuccessMessage = null;
            await InvokeAsync(StateHasChanged);
        }

        if (!string.IsNullOrWhiteSpace(_viewModel.ErrorMessage) && (_viewModel.Employees?.Any() ?? false))
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Error",
                Text = _viewModel.ErrorMessage,
                RenderStyle = ToastRenderStyle.Danger,
                ThemeMode = ToastThemeMode.Pastel
            });

            _viewModel.ErrorMessage = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnSearchTextChanged(string? value)
    {
        if (_viewModel is null)
            return;

        await _viewModel.OnSearchInput(new ChangeEventArgs
        {
            Value = value ?? string.Empty
        });

        SyncPagerState();
        StateHasChanged();
    }

    private int SelectedPageSize
    {
        get => _selectedPageSize;
        set
        {
            if (_selectedPageSize == value)
                return;

            _selectedPageSize = value;
            _ = ApplyPageSizeAsync(value);
        }
    }

    private int PagerActivePageIndex
    {
        get => _pagerActivePageIndex;
        set
        {
            if (_pagerActivePageIndex == value)
                return;

            _pagerActivePageIndex = value;
            _ = LoadSelectedPageAsync(value);
        }
    }

    private async Task ApplyPageSizeAsync(int newSize)
    {
        if (_viewModel is null)
            return;

        await _viewModel.SetPageSizeAsync(newSize);
        SyncPagerState();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadSelectedPageAsync(int pageIndex)
    {
        if (_viewModel is null)
            return;

        await _viewModel.GoToPage(pageIndex + 1);
        SyncPagerState();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmDeleteAsync(EmployeeViewModel employee)
    {
        if (_viewModel is null)
            return;

        var confirmed = await DialogService.ConfirmAsync(new MessageBoxOptions
        {
            Title = "Delete Employee",
            Text = $"Are you sure you want to delete employee '{employee.Name}'?",
            OkButtonText = "Delete",
            CancelButtonText = "Cancel",
            RenderStyle = MessageBoxRenderStyle.Danger
        });

        if (!confirmed)
            return;

        await _viewModel.DeleteEmployeeConfirmedAsync(employee.Id);
        SyncPagerState();
        StateHasChanged();
    }

    private void SyncPagerState()
    {
        if (_viewModel is null)
            return;

        _selectedPageSize = _viewModel.PageSize;
        _pagerActivePageIndex = _viewModel.ActivePageIndex;
    }

}
