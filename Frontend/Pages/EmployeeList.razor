@page "/"
@using Frontend.Components

<h3>Employee List</h3>

<!-- Notification Area -->
<Notification Message="@successMessage" AlertType="success" Duration="5000" />
<Notification Message="@errorMessage" AlertType="success" Duration="5000" />

<!-- Filter Form -->
<div class="mb-3">
    <input class="form-control" placeholder="Search by Name, Position or Department"
           @bind="searchTerm" @bind:event="on input" />
</div>

<button class="btn btn-primary mb-3" @onclick="AddEmployee">Add New Employee</button>

<!-- Loading Indicator -->
@if (isLoading)
{
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
}
else if (!FilteredEmployees.Any())
{
    <p>No employees found.</p>
}
else
{
    <!-- Table Of Employee Values -->
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Position</th>
                <th>Department</th>
                <th>Salary</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var employee in FilteredEmployees)
            {
                <tr>
                    <td>@employee.Id</td>
                    <td>@employee.Name</td>
                    <td>@employee.Position</td>
                    <td>@employee.Department</td>
                    <td>@employee.Salary.ToString("C")</td>
                    <td>
                        <!-- Edit Button-->
                        <button class="btn btn-sm btn-outline-secondary me-2" @onclick="() => EditEmployee(employee.Id)">Edit</button>
                        <!-- Add Button-->
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteEmployee(employee.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Pagination UI-->
    <div>
        <button @onclick="() => GoToPage(currentPage - 1)" disabled="@((currentPage == 1))">Previous</button>
        <span>Page @currentPage of @totalPages</span>
        <button @onclick="() => GoToPage(currentPage + 1)" disabled="@((currentPage == totalPages))">Next</button>
    </div>
}
