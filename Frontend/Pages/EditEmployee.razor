@page "/edit/{Id:int}"

@if (_viewModel != null && _viewModel.Initialized)
{
    <PageTitle>@_viewModel.PageTitle</PageTitle>
    <h3>Edit Employee</h3>

    <!-- Notification Area -->
    <Notification @bind-Message="_viewModel.SuccessMessage" AlertType="success" />
    <Notification @bind-Message="_viewModel.ErrorMessage" AlertType="danger" />

    @if (_viewModel.Employee != null)
    {
        <!-- Employee Form -->
        <EditForm EditContext="_editContext" OnValidSubmit="_viewModel.HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label>Name</label>
                <InputText class="form-control" @bind-Value="_viewModel.Employee.Name" />
                <ValidationMessage For="@(() => _viewModel.Employee.Name)" />
            </div>
            <div class="mb-3">
                <label>Position</label>
                <InputText class="form-control" @bind-Value="_viewModel.Employee.Position" />
                <ValidationMessage For="@(() => _viewModel.Employee.Position)" />
            </div>
            <div class="mb-3">
                <label>Department</label>
                <InputText class="form-control" @bind-Value="_viewModel.Employee.Department" />
                <ValidationMessage For="@(() => _viewModel.Employee.Department)" />
            </div>
            <div class="mb-3">
                <label>Salary</label>
                <InputNumber class="form-control" @bind-Value="_viewModel.Employee.Salary" />
                <ValidationMessage For="@(() => _viewModel.Employee.Salary)" />
            </div>
            <button class="btn btn-primary" type="submit" disabled="@(!_isFormValid)">Edit Employee</button>
            <button class="btn btn-secondary ms-2" type="button" @onclick="_viewModel.GoBack">Go Back</button>
            <button class="btn btn-warning ms-2" type="button" @onclick="ResetForm">Reset</button>
        </EditForm>
    }
    else
    {
        <p>Employee doesn't exist.</p>
    }
}
else
{
    <!-- Loading Indicator -->
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    EditEmployeeViewModel? _viewModel;
    EditContext? _editContext;
    bool _isFormValid = false;
    bool _needsValidation = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _viewModel = new EditEmployeeViewModel(this, client, navigationManager, JSRuntime, Id);
            await _viewModel.InitializeAsync();

            if (_viewModel.Employee != null)
            {
                _editContext = new EditContext(_viewModel.Employee);
                _editContext.OnFieldChanged += (_, __) => ValidateForm();
                _needsValidation = true;
            }
            StateHasChanged();
        }
        else if (_needsValidation)
        {
            _needsValidation = false;
            ValidateForm();
        }
    }

    private void ValidateForm()
    {
        if (_editContext != null)
            _isFormValid = _editContext.Validate();
        StateHasChanged();
    }

    private void ResetForm()
    {
        if (_viewModel?.Employee != null && _viewModel?.OriginalEmployee != null)
        {
            // Copy properties 
            _viewModel.Employee.Name = _viewModel.OriginalEmployee.Name;
            _viewModel.Employee.Position = _viewModel.OriginalEmployee.Position;
            _viewModel.Employee.Department = _viewModel.OriginalEmployee.Department;
            _viewModel.Employee.Salary = _viewModel.OriginalEmployee.Salary;
        }
        _editContext?.Validate();
        StateHasChanged();
    }
}
