@page "/add"
@inject Microsoft.Extensions.Logging.ILogger<AddEmployeeViewModel> addEmployeeLogger
@using Frontend.Models

@if (_viewModel != null && _viewModel.Initialized)
{
    <PageTitle>@_viewModel.PageTitle</PageTitle>
    <h3>Add Employee</h3>

    @if (!string.IsNullOrWhiteSpace(_viewModel.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @_viewModel.ErrorMessage
        </div>
    }

    <EditForm EditContext="_editContext" OnValidSubmit="_viewModel.HandleValidSubmit" Context="editFormContext">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <DxFormLayout CaptionPosition="@CaptionPosition.Vertical">
            <DxFormLayoutItem Caption="Name">
                <DxTextBox @bind-Text="_viewModel.Employee.Name"
                           BindValueMode="@BindValueMode.OnDelayedInput"
                           NullText="Enter employee name" />
                <ValidationMessage For="@(() => _viewModel.Employee.Name)" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="Position">
                <DxTextBox @bind-Text="_viewModel.Employee.Position"
                           BindValueMode="@BindValueMode.OnDelayedInput"
                           NullText="Enter employee position" />
                <ValidationMessage For="@(() => _viewModel.Employee.Position)" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="Department">
                <DxComboBox TData="DepartmentDto"
                            TValue="string"
                            Data="@_viewModel.Departments"
                            ValueFieldName="Name"
                            TextFieldName="Name"
                            @bind-Text="_viewModel.Employee.DepartmentName"
                            BindValueMode="@BindValueMode.OnInput"
                            AllowUserInput="true"
                            NullText="Select or enter a department"
                            ClearButtonDisplayMode="@DataEditorClearButtonDisplayMode.Auto" />
                <ValidationMessage For="@(() => _viewModel.Employee.DepartmentName)" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="Salary">
                <DxSpinEdit @bind-Value="_viewModel.Employee.Salary"
                            BindValueMode="@BindValueMode.OnDelayedInput"
                            NullText="Enter salary"
                            MinValue="0m"
                            Increment="100m" />
                <ValidationMessage For="@(() => _viewModel.Employee.Salary)" />
            </DxFormLayoutItem>

            <DxFormLayoutItem ColSpanMd="12">
                <div class="d-flex gap-2 flex-wrap mt-3">
                    <DxButton Text="Add Employee"
                              RenderStyle="@ButtonRenderStyle.Primary"
                              Enabled="@_isFormValid"
                              SubmitFormOnClick="true" />

                    <DxButton Text="Go Back"
                              RenderStyle="@ButtonRenderStyle.Secondary"
                              Click="_viewModel.GoBack" />

                    <DxButton Text="Reset"
                              RenderStyle="@ButtonRenderStyle.Warning"
                              Click="ResetForm" />
                </div>
            </DxFormLayoutItem>
        </DxFormLayout>
    </EditForm>
}
else
{
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
}

@code {
    private AddEmployeeViewModel? _viewModel;
    private EditContext? _editContext;
    private bool _isFormValid;
    private bool _needsValidation;

    protected override async Task OnInitializedAsync()
    {
        _viewModel = new AddEmployeeViewModel(this, client, navigationManager, JSRuntime, addEmployeeLogger);
        _editContext = new EditContext(_viewModel.Employee);
        _editContext.OnFieldChanged += (_, __) => ValidateForm();
        _needsValidation = true;

        await _viewModel.InitializeAsync();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _needsValidation)
        {
            _needsValidation = false;
            ValidateForm();
        }

        return Task.CompletedTask;
    }

    private void ValidateForm()
    {
        if (_editContext is not null)
            _isFormValid = _editContext.Validate();

        StateHasChanged();
    }

    private void ResetForm()
    {
        _viewModel?.ResetForm();
        _editContext?.Validate();
        StateHasChanged();
    }

}