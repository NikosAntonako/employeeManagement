@inject ILogger<DxPopupErrorBoundary> Logger
@inject NavigationManager Navigation

<ErrorBoundary @ref="_errorBoundary">
    <ChildContent>
        @ChildContent
    </ChildContent>
    <ErrorContent Context="exception">
        @{
            LogException(exception);
        }

        <DxPopup Visible="true"
                 HeaderText="Unexpected error"
                 CloseOnOutsideClick="false"
                 ShowCloseButton="false"
                 Width="420px">
            <BodyContentTemplate>
                <p class="mb-0">Something went wrong. Please try again later.</p>
            </BodyContentTemplate>
            <FooterContentTemplate>
                <div class="d-flex justify-content-end gap-2">
                    <DxButton Text="Go Home"
                              RenderStyle="ButtonRenderStyle.Secondary"
                              Click="GoHome" />
                    <DxButton Text="Reload"
                              RenderStyle="ButtonRenderStyle.Primary"
                              Click="ReloadPage" />
                </div>
            </FooterContentTemplate>
        </DxPopup>
    </ErrorContent>
</ErrorBoundary>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private ErrorBoundary? _errorBoundary;
    private Exception? _lastLoggedException;

    private void LogException(Exception exception)
    {
        if (ReferenceEquals(_lastLoggedException, exception))
            return;

        _lastLoggedException = exception;
        Logger.LogError(exception, "Unhandled exception captured by ErrorBoundary");
    }

    private void ReloadPage()
    {
        _lastLoggedException = null;
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }

    private void GoHome()
    {
        _lastLoggedException = null;
        Navigation.NavigateTo("/");
    }
}